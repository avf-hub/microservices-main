<?xml version="1.0" encoding="UTF-8"?>


<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <changeSet id="create-order-tables" author="alex-v-yakunin" context="ordering">
        <createTable tableName="customer_orders">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true"
                             nullable="false"
                             unique="true"/>
            </column>
            <column name="customer_id" type="bigint"/>
            <column name="order_state" type="varchar(50)"/>
        </createTable>
        <createTable tableName="order_items">
            <column name="order_id" type="bigint">
                <constraints nullable="false"
                             foreignKeyName="fk_order_items_customer_orders"
                             references="customer_orders(id)"/>
            </column>
            <column name="product_id" type="bigint"/>
            <column name="qty" type="bigint"/>
            <column name="cost" type="numeric"/>
        </createTable>
    </changeSet>
    <changeSet id="create-outbox_messages-table" author="falkovskiy-av">
        <createTable tableName="outbox_messages">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true"
                             nullable="false"
                             unique="true"/>
            </column>
            <column name="message" type="varchar(300)"/>
            <column name="sent" type="boolean"/>
            <column name="date" type="datetime"/>
        </createTable>
    </changeSet>
</databaseChangeLog>
