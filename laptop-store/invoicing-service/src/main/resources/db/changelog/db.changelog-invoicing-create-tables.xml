<?xml version="1.0" encoding="UTF-8"?>


<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <changeSet id="create-invoices-table" author="alex-v-yakunin" context="invoicing">
        <createTable tableName="invoices">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false" unique="true"/>
            </column>
            <column name="order_id" type="bigint"/>
            <column name="customer_id" type="bigint"/>
        </createTable>
        <createTable tableName="invoice_items">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false" unique="true"/>
            </column>
            <column name="invoice_id" type="bigint">
                <constraints nullable="true"
                             foreignKeyName="fk_invoice_items_invoices"
                             references="invoices(id)"/>
            </column>
            <column name="idx" type="integer"/>
            <column name="product_id" type="bigint"/>
            <column name="qty" type="bigint"/>
            <column name="cost" type="numeric"/>
        </createTable>
    </changeSet>
</databaseChangeLog>
