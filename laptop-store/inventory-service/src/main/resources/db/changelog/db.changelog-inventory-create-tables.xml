<?xml version="1.0" encoding="UTF-8"?>


<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <changeSet id="create-inventory_items-table" author="alex-v-yakunin" context="inventory">
        <createTable tableName="inventory_items">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false" unique="true"/>
            </column>
            <column name="product_id" type="bigint"/>
            <column name="available_qty" type="bigint"/>
            <column name="unit_cost" type="number"/>
        </createTable>
    </changeSet>

    <changeSet id="create-item_reservation_records-table" author="alex-v-yakunin" context="inventory">
        <createTable tableName="item_reservation_records">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false" unique="true"/>
            </column>
            <column name="inventory_item_id" type="bigint"/>
            <column name="product_id" type="bigint"/>
            <column name="required_qty" type="bigint"/>
            <column name="unit_cost" type="number"/>
        </createTable>
    </changeSet>
</databaseChangeLog>
